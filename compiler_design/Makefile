# ============================================================
#  Makefile for the Mini Rust Compiler
# ============================================================
#  Prerequisites (must be on your PATH):
#    - win_flex   (WinFlexBison package)
#    - win_bison  (WinFlexBison package)
#    - gcc        (MinGW / TDM-GCC / MSYS2)
#
#  Usage:
#    make            — build the compiler (compiler.exe)
#    make run        — build and run with test.rs
#    make errors     — build and run with test_errors.rs
#    make clean      — remove generated files
# ============================================================

CC       = gcc
FLEX     = win_flex
BISON    = win_bison
CFLAGS   = -g
TARGET   = compiler.exe

# Source files generated by Flex / Bison
LEX_OUT  = lex.yy.c
PARSE_OUT= parser.tab.c
PARSE_HDR= parser.tab.h

# Hand-written sources
SRCS     = symbol_table.c intermediate_code.c parse_tree.c main.c

# ---- Build targets ----

all: $(TARGET)

# Step 1: Run Flex on lexer.l  →  lex.yy.c
$(LEX_OUT): lexer.l
	$(FLEX) lexer.l

# Step 2: Run Bison on parser.y  →  parser.tab.c + parser.tab.h
$(PARSE_OUT) $(PARSE_HDR): parser.y
	$(BISON) -d parser.y

# Step 3: Compile everything together
$(TARGET): $(LEX_OUT) $(PARSE_OUT) $(SRCS)
	$(CC) $(CFLAGS) -o $(TARGET) $(LEX_OUT) $(PARSE_OUT) $(SRCS)

# ---- Convenience targets ----

run: $(TARGET)
	./$(TARGET) test.rs

errors: $(TARGET)
	./$(TARGET) test_errors.rs

clean:
	del /Q $(LEX_OUT) $(PARSE_OUT) $(PARSE_HDR) $(TARGET) parsetree.txt 2>nul || true

.PHONY: all run errors clean
